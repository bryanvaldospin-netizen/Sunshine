/**
 * Core Philosophy: This ruleset implements a secure model where users can only access their own data,
 * except for administrators who have elevated privileges.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles. Users manage their own profile. Admins can manage all profiles.
 * - /admins/{adminId}: Stores a list of administrator UIDs and their roles. This collection governs who gets admin privileges.
 * - /invitation_codes/{invitationCodeId}: Publicly readable codes for registration. Writable by admins.
 * - /deposit_requests/{reqId}: A global collection of all deposit requests, manageable only by admins.
 *
 * Key Security Decisions:
 * - Admin Access: A user is considered an admin if their UID is in the /admins collection with role: 'admin', or if they are the hardcoded Master Admin.
 * - Master Admin: A specific UID ('daNNsN4y5lgsTtrioMXNXcX24ZH2') has irrevocable super-admin privileges.
 * - Granular Permissions: Non-admin users have strict, owner-based access to their own data.
 * - Collection Groups: Admins use a collection group query on 'deposit_requests' to manage all requests across all users.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for DRY and readable rules
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the user is a designated administrator.
    // The Master Admin UID is also hardcoded for ultimate authority.
    function isAdmin() {
      return request.auth.uid == 'daNNsN4y5lgsTtrioMXNXcX24ZH2' ||
             (isSignedIn() && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin');
    }

    // Rules for user profiles
    match /users/{userId} {
      // Admins can read/write any user document
      allow read, write: if isAdmin();
      
      // A user can read their own document
      allow get: if isOwner(userId);
      
      // Admins can list all users, regular users cannot.
      allow list: if isAdmin();
      
      // A user can create their own profile
      allow create: if isOwner(userId);
      
      // A user can update their own profile, but not sensitive fields like balance or role
      allow update: if isOwner(userId) && request.resource.data.saldoUSDT == resource.data.saldoUSDT && request.resource.data.rol == resource.data.rol;
      
      // Nobody can delete users for now.
      allow delete: if false;
    }

    // Rules for the subcollection of deposit requests within a user document (less used now, but good practice)
    match /users/{userId}/deposit_requests/{depositRequestId} {
      // A user can manage their own deposit requests
      allow get, list, create: if isOwner(userId) && request.resource.data.userId == userId;
      // Users cannot update or delete their requests
      allow update, delete: if false;
    }
    
    // Rules for the top-level collection of all deposit requests, used for admin panel
    match /deposit_requests/{reqId} {
        // Only Admins can read, list, and update these requests.
        allow read, list, update: if isAdmin();
        // Users can create requests here.
        allow create: if request.resource.data.userId == request.auth.uid;
        // Nobody can delete from the top-level collection for now.
        allow delete: if false;
    }
    
    // This rule is critical for the admin panel to query all deposit requests from all users at once.
    match /{path=**}/deposit_requests/{reqId} {
        allow read, list, update: if isAdmin();
    }

    // Rules for invitation codes
    match /invitation_codes/{invitationCodeId} {
      // Admins can manage codes
      allow read, write: if isAdmin();
      // Anyone can check if a code exists for registration purposes
      allow get: if true;
    }

    // Rules for the admins collection itself
    match /admins/{adminId} {
      // Only the master admin can add, edit, or remove other admins
      allow write: if request.auth.uid == 'daNNsN4y5lgsTtrioMXNXcX24ZH2';
      // All admins can see who else is an admin
      allow read, list: if isAdmin();
    }
  }
}

    