rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for DRY and readable rules
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Rules for user profiles
    match /users/{userId} {
      // A user can read their own profile, or the profiles of users they referred.
      // This rule is necessary to enable the "My Network" query.
      allow read: if isOwner(userId) || (resource.data.invitadoPor != null && resource.data.invitadoPor == request.auth.uid);
      
      // Allow user creation with specific fields validation for security.
      allow create: if isOwner(userId)
                    && request.resource.data.uid == userId
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.name is string && request.resource.data.name.size() > 1
                    && request.resource.data.rol == 'user'
                    && request.resource.data.saldoUSDT == 0
                    && request.resource.data.walletAddress is string && request.resource.data.walletAddress.size() > 20
                    && request.resource.data.planActivo == 0
                    && request.resource.data.fechaInicioPlan == null
                    && request.resource.data.bonoDirecto == 0
                    && request.resource.data.fechaRegistro is string
                    && request.resource.data.keys().hasOnly(['uid', 'name', 'email', 'rol', 'saldoUSDT', 'invitadoPor', 'inviteCode', 'walletAddress', 'ultimoCheckIn', 'planActivo', 'fechaInicioPlan', 'bonoDirecto', 'fechaRegistro']);

      // This rule allows a user to update their own profile, such as for the daily bonus,
      // while preventing them from changing their role.
      allow update: if isOwner(userId) && request.resource.data.rol == resource.data.rol;
      
      // Nobody can delete users to protect user data.
      allow delete: if false;
    }

    // Rules for the subcollection of deposit requests within a user document
    match /users/{userId}/deposit_requests/{depositRequestId} {
      // A user can read and list their own deposit requests.
      allow get, list: if isOwner(userId);
      
      // A user can create a deposit request for themselves.
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      
      // Users cannot update or delete their requests once created.
      allow update, delete: if false;
    }
    
    // Rules for the top-level collection of all deposit requests
    match /deposit_requests/{reqId} {
        // Users can create requests here. The data must contain their own UID.
        allow create: if request.resource.data.userId == request.auth.uid;

        // No one can read, update or delete from the top-level collection directly
        allow read, list, update, delete: if false;
    }

    // Rules for the investments collection
    match /investments/{investmentId} {
      // A user can get their own investment document.
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      // A user can list investments. The client-side code is responsible for filtering by the user's ID.
      allow list: if isSignedIn();
      // Nobody can write to investments from the client.
      allow write: if false;
    }

    // Rules for invitation codes (single-use, deprecated)
    match /invitation_codes/{invitationCodeId} {
      // Anyone can check if a code exists for registration purposes
      allow get: if true;
      // Nobody else can list or write codes.
      allow list, write: if false;
    }

    // Rules for wallet address uniqueness check
    match /wallet_addresses/{walletAddress} {
        // Allow anyone (even unauthenticated users) to check if a wallet address exists.
        // This is safe because the document contains no sensitive information.
        allow get: if true;

        // Allow creation only if the user is authenticated and the userId in the document
        // matches their own UID. This prevents users from claiming wallets for others.
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

        // Disallow listing, updating, or deleting to protect the integrity of the records.
        allow list, update, delete: if false;
    }

    // Rules for invite code mapping for sponsor lookup
    match /invite_codes_map/{inviteCode} {
      // Allow anyone (unauthenticated users) to look up a sponsor code.
      // This is safe as it only reveals the existence of a code. The document doesn't contain sensitive data.
      allow get: if true;

      // Allow a user to create their own invite code mapping upon registration.
      // The userId in the document must match their own UID.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      // Disallow listing, updating, or deleting to protect integrity.
      allow list, update, delete: if false;
    }
  }
}
