rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for DRY and readable rules
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Rules for user profiles
    match /users/{userId} {
      // A user can read their own profile, or the profiles of users they referred.
      allow read: if isOwner(userId) || (resource.data.invitadoPor != null && resource.data.invitadoPor == request.auth.uid);
      
      // No one can list all users.
      allow list: if false;
      
      // Allow user creation with specific fields validation for security.
      allow create: if isOwner(userId)
                    && request.resource.data.uid == userId
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.name is string && request.resource.data.name.size() > 1
                    && request.resource.data.rol == 'user'
                    && request.resource.data.saldoUSDT == 0
                    && request.resource.data.walletAddress is string && request.resource.data.walletAddress.size() > 20
                    && request.resource.data.planActivo == 0
                    && request.resource.data.inversionAnterior == 0
                    && request.resource.data.fechaInicioPlan == null
                    && request.resource.data.bonoDirecto == 0
                    && request.resource.data.bonoEntregado == false
                    && request.resource.data.fechaRegistro is string
                    && request.resource.data.keys().hasOnly(['uid', 'name', 'email', 'rol', 'saldoUSDT', 'invitadoPor', 'inviteCode', 'walletAddress', 'ultimoCheckIn', 'planActivo', 'fechaInicioPlan', 'bonoDirecto', 'fechaRegistro', 'bonoEntregado', 'inversionAnterior', 'totalInvested', 'bonoRetirable', 'hasUnclaimedBonuses', 'lastConsolidation', 'retirosTotales']);

      // This rule allows a user to update their own profile BUT prevents them
      // from changing their balance, bonuses, plan, or role from the client.
      allow update: if isOwner(userId)
                    && request.resource.data.saldoUSDT == resource.data.saldoUSDT
                    && request.resource.data.bonoDirecto == resource.data.bonoDirecto
                    && request.resource.data.planActivo == resource.data.planActivo
                    && request.resource.data.rol == resource.data.rol;
      
      // Nobody can delete users to protect user data.
      allow delete: if false;

      // Rules for user transactions subcollection
      match /transacciones/{transactionId} {
        // A user can read their own transactions.
        allow read, list: if isOwner(userId);
        // Only the server can create/update/delete transactions.
        allow write: if false;
      }
    }

    // Rules for invitation codes (single-use, deprecated)
    match /invitation_codes/{invitationCodeId} {
      // Anyone can check if a code exists for registration purposes
      allow get: if true;
      // Nobody else can list or write codes.
      allow list, write: if false;
    }

    // Rules for wallet address uniqueness check
    match /wallet_addresses/{walletAddress} {
        // Allow authenticated users to check if a specific wallet address exists.
        allow get: if isSignedIn();
        // Disallow listing all wallets, and all writes from the client.
        // Creation is handled by a secure server action.
        allow list, write: if false;
    }

    // Rules for invite code mapping for sponsor lookup
    match /invite_codes_map/{inviteCode} {
      // Allow anyone (unauthenticated users) to look up a sponsor code.
      allow get: if true;

      // Allow a user to create their own invite code mapping upon registration.
      // The userId in the document must match their own UID.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      // Disallow listing, updating, or deleting to protect integrity.
      allow list, update, delete: if false;
    }
    
    // Rules for withdrawal requests
    match /retiro_tokens/{tokenId} {
        // Allow a user to create and read their OWN withdrawal requests.
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.uid;
        allow read: if isSignedIn() && request.auth.uid == resource.data.uid;
        // Prohibit updating or deleting from the client.
        allow update, delete: if false;
    }
    
    // Rules for deposit requests
    match /deposit_requests/{depositId} {
        // Allow a user to create and read their OWN deposit requests.
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.uid;
        allow read: if isSignedIn() && request.auth.uid == resource.data.uid;
        // Prohibit updating or deleting from the client.
        allow update, delete: if false;
    }
  }
}
